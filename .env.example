# Copy to .env for local runs. Never commit a real .env file.
# For a different target environment, create .env.<name> and set TEST_ENV=<name>
# (e.g. .env.staging + TEST_ENV=staging) — see docs/environments.md.

TEST_ENV=local
UI_BASE_URL=https://playwright.dev
API_BASE_URL=https://jsonplaceholder.typicode.com
